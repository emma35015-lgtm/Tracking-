# Copia este archivo a .env.local y llena los valores desde tu proyecto de Supabase
# (Dashboard de Supabase → Settings → API)

# URL del proyecto, ej. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# "anon public" key (segura para el navegador, protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# "service_role" key (SOLO servidor — la usa /api/ingest; nunca la expongas)
SUPABASE_SERVICE_ROLE_KEY=
